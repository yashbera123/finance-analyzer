# Application
APP_ENV=production
SECRET_KEY=replace-with-a-long-random-secret

# Vercel frontend origin. Add preview domains only when intentionally allowed.
CORS_ORIGINS=https://your-vercel-project.vercel.app

# Production database. Use a managed PostgreSQL instance on Render, Neon, Supabase, etc.
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/finance_db

# Optional provider keys.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional cache/session infrastructure.
REDIS_URL=
