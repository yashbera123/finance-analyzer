# Application
APP_ENV=development
SECRET_KEY=change-me-in-production
PORT=8000

# Comma-separated allowed frontend origins.
CORS_ORIGINS=http://localhost:3000

# Local default. Use postgresql+asyncpg://user:password@host:5432/db for production.
DATABASE_URL=sqlite+aiosqlite:///./finance_analyzer.db

# Optional provider keys.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional cache/session infrastructure.
REDIS_URL=redis://localhost:6379
